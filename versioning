	public static boolean checkDate( String s1 )
	{
		// s1= "29/02/1000"; // test
		String s0 = "";
		int k1 = 0;
		int k2 = 0;
		int [] giorni = { 31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 };
		// data lunga 0 è vuota (da non considerare)
		if ( (s1.length()==0) )
		{
			return true;
		}
		if ( !(s1.length()==10) )
		{
			System.out.println( "Non è lungo 10 ma "+s1.length() );
			return false;
		}
		for (int i=0;i<s1.length();i++)
		{
			s0 = s1.substring( i, i+1 );
			if ( i==2 || i==5 )
			{
				if ( !s0.equals( "/") )
				{
					System.out.println( "non  è /: ("+s0+")" );
					return false;
				}
			}
			else
			{
				if ( !"0123456789".contains( s0 ) )
				{
					System.out.println( "Non è numero: ("+s0+")" );
					return false;
				}
			}
		}
		// check se la data è valida
		int giorno = Integer.parseInt(s1.substring( 0, 2 ));
		int mese = Integer.parseInt(s1.substring( 3, 5 ));
		int anno = Integer.parseInt(s1.substring( 6, 10 ));
		if ( mese==0 || anno==0 || giorno==0 || mese>12 || giorno>31 )
		{
			return false;
		}
		// controlla giorni del mese
		if ( giorno > giorni[mese-1] )
		{
			System.out.println( "Giorno "+giorno+" del mese "+mese+" NON esiste!" );
			return false;
		}
		if ( mese == 2 )
		{
			if ( giorno == 29 )
			{
				if ( (anno%4) > 0 )
				{
					System.out.println( "Anno NON bistile!!!" );
					return false;
				}
			}
		}
		return true;
	}
	
	
