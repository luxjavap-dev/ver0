                break;
            case winGenConstants.BUTTON:
                comp = new JButton(testo);
                break;
            case winGenConstants.LABEL:
                comp = new JLabel(testo);
                break;
            default:
                comp = new JLabel("Tipo non supportato");
        }

        comp.setBounds(x, y, larghezza, altezza);
        return comp;
    }
