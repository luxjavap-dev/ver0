    // START	avviaUpdateThread

private void avviaUpdateThread() {
        updateThread = new Thread(() -> {
            System.out.println("  [Versioning] Thread update avviato");
            
            // Primo controllo immediato all'avvio
            if (running && !updateInCorso) {
                checkForUpdates();
            }

            while (running && !Thread.currentThread().isInterrupted()) {
                try {
                    // Attesa di 15 secondi tra un controllo e l'altro
                    for (int i = 0; i < 15 && running; i++) Thread.sleep(1000);
                    
                    if (running && !updateInCorso) {
                        checkForUpdates();
                    }
                } catch (InterruptedException e) {
                    break;
                }
            }
            System.out.println("  [Versioning] Thread update terminato");
        });
        updateThread.start();
    }

    // END	avviaUpdateThread

    
    private void fermaUpdateThread() {
        if (updateThread != null) {
            updateThread.interrupt();
            try { updateThread.join(3000); } catch (InterruptedException e) {}
            updateThread = null;
        }
    }
	    
	private void avviaStopCheckThread() {
	    stopCheckThread = new Thread(() -> {
		   System.out.println("  [Versioning] Thread stop check avviato (controllo ogni 10 sec)");
		   int ciclo = 0;
		   while (running && !Thread.currentThread().isInterrupted()) {
			  try {
				 for (int i = 0; i < 10 && running; i++) Thread.sleep(1000);
				 if (running && !updateInCorso) {
					ciclo++;
					boolean stopped = isStopped();
					
					if (stopped) {
					    System.out.println("");
					    System.out.println("╔══════════════════════════════════════════════════════════════╗");
					    System.out.println("║  🛑 RILEVATO STATO STOPPED!                                   ║");
					    System.out.println("║  Il programma verrà chiuso.                                  ║");
					    System.out.println("╚══════════════════════════════════════════════════════════════╝");
					    System.out.println("");
					    
					    closeDatabaseConnection();
					    if (callback != null) callback.onStopRequested();
					    SwingUtilities.invokeLater(() -> mostraFinestraStop());
					    running = false;
					    break;
					} else {
					    System.out.println("  [Versioning] ✅ Stato: RUNNING (ciclo #" + ciclo + ")");
					}
				 }
			  } catch (InterruptedException e) {
				 break;
			  }
		   }
		   System.out.println("  [Versioning] Thread stop check terminato");
	    });
	    stopCheckThread.start();
	}


    
    private void fermaStopCheckThread() {
        if (stopCheckThread != null) {
            stopCheckThread.interrupt();
            try { stopCheckThread.join(3000); } catch (InterruptedException e) {}
            stopCheckThread = null;
        }
    }
    
