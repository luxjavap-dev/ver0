        }
        return false;
    }
    
    // ==================== CONTROLLO AGGIORNAMENTI ====================
    public boolean checkForUpdates() {
        if (numeroApplicazione == null) {
            System.out.println("  [Versioning] Skippato: numeroApplicazione = null");
            return false;
        }
        if (updateInCorso) {
            System.out.println("  [Versioning] Skippato: update già in corso");
            return false;
        }
        
        System.out.println("  [Versioning] Controllo aggiornamenti in corso...");
        
        try {
            String sql = "SELECT NUMEROVERSIONEATTIVA, RUNNINGSTOPPED FROM applicazioni WHERE NUMEROAPPLICAZIONE = ?";
            try (PreparedStatement pstmt = conn.prepareStatement(sql)) {
                pstmt.setString(1, numeroApplicazione);
                ResultSet rs = pstmt.executeQuery();
                
                if (rs.next()) {
                    String dbVersione = rs.getString("NUMEROVERSIONEATTIVA");
                    String runningStopped = rs.getString("RUNNINGSTOPPED");
                    
                    System.out.println("  │ Versione sul DB: " + dbVersione);
                    System.out.println("  │ Versione locale: " + versioneProgrammaDb);
                    System.out.println("  │ Stato: " + runningStopped);
                    
                    if ("Stopped".equals(runningStopped)) {
                        System.out.println("  [Versioning] Applicazione in stato STOPPED, nessun controllo aggiornamenti");
                        return false;
                    }
                    
                    int confronto = confrontaVersioni(dbVersione, versioneProgrammaDb);
                    System.out.println("  │ dbVersione: " + dbVersione + "versioneProgrammaDb " + versioneProgrammaDb);
                    System.out.println("  │ Confronto: " + (confronto > 0 ? "nuova versione" : confronto < 0 ? "versione precedente" : "uguale"));
                    
                    if (confronto > 0) {
                        System.out.println("");
                        System.out.println("╔══════════════════════════════════════════════════════════════╗");
                        System.out.println("║  🚀 NUOVA VERSIONE DISPONIBILE!                              ║");
                        System.out.println("║  Versione server: " + formatVersione(dbVersione) + "                                      ║");
                        System.out.println("║  Versione locale: " + formatVersione(versioneProgrammaDb) + "                                      ║");
                        System.out.println("╚══════════════════════════════════════════════════════════════╝");
                        System.out.println("");
                        
                        if (callback != null) callback.onUpdateAvailable(formatVersione(dbVersione));
                        eseguiUpdate(dbVersione);
                        return true;
                    } else {
                        System.out.println("  [Versioning] Nessun aggiornamento disponibile");
                    }
                } else {
                    System.out.println("  [Versioning] Nessun risultato dalla query");
                }
            }
        } catch (SQLException e) {
            System.err.println("  ✗ Errore controllo versioni: " + e.getMessage());
        }
        return false;
    }
    
    private int confrontaVersioni(String v1, String v2) {
        if (v1 == null || v2 == null) return 0;
        if (v1.length() < 5 || v2.length() < 5) return 0;
        
        try {
            int major1 = Integer.parseInt(v1.substring(0, 3));
            int minor1 = Integer.parseInt(v1.substring(3, 5));
            int major2 = Integer.parseInt(v2.substring(0, 3));
            int minor2 = Integer.parseInt(v2.substring(3, 5));
            
            if (major1 > major2) return 1;
            if (major1 < major2) return -1;
            if (minor1 > minor2) return 1;
            if (minor1 < minor2) return -1;
        } catch (NumberFormatException e) {
            System.err.println("  ✗ Errore parsing versioni: " + v1 + ", " + v2);
        }
        return 0;
    }
    
    private String formatVersione(String dbVersione) {
        if (dbVersione == null || dbVersione.length() < 5) return "0.0";
        try {
            int major = Integer.parseInt(dbVersione.substring(0, 3));
            int minor = Integer.parseInt(dbVersione.substring(3, 5));
            return major + "." + minor;
        } catch (NumberFormatException e) {
            return "0.0";
        }
    }
    
    // ==================== ESECUZIONE UPDATE ====================
    private void eseguiUpdate(String versioneDb) {
        System.out.println("  [Versioning] Avvio procedura di update...");
        updateInCorso = true;
        
        // Mostra dialog "Update in corso"
        SwingUtilities.invokeLater(() -> mostraUpdateInCorso());
        
        // Ferma stopCheckThread durante l'update
        fermaStopCheckThread();
        
        // Scarica i file
        System.out.println("  [Versioning] Download dei file...");
        scaricaFileVersione(versioneDb);
        System.out.println("  [Versioning] ✓ Download completato!");
        
        // Chiudi dialog "Update in corso"
        SwingUtilities.invokeLater(() -> chiudiUpdateInCorso());
        
        // Notifica completamento
        if (callback != null) callback.onUpdateCompleted();
        
        // Mostra dialog "Update terminato"
        SwingUtilities.invokeLater(() -> mostraUpdateTerminato());
        
        // Ferma tutto
        running = false;
        fermaUpdateThread();
    }
    
    private void scaricaFileVersione(String versioneDb) {
        try {
            String sql = "SELECT TIPO, DIRECTORY, FILE, BLOBFILE FROM files " +
                        "WHERE NUMEROAPPLICAZIONE = ? AND NUMEROVERSIONE = ?";
            
            try (PreparedStatement pstmt = conn.prepareStatement(sql)) {
                pstmt.setString(1, numeroApplicazione);
                pstmt.setString(2, versioneDb);
                ResultSet rs = pstmt.executeQuery();
                
                int fileScaricati = 0;
                while (rs.next()) {
                    String fileName = rs.getString("FILE");
                    Blob blob = rs.getBlob("BLOBFILE");
                    
                    if (blob != null && fileName != null && !fileName.isEmpty()) {
                        try (InputStream is = blob.getBinaryStream();
                             OutputStream os = new FileOutputStream("./" + fileName)) {
                            byte[] buffer = new byte[8192];
                            int bytesRead;
                            while ((bytesRead = is.read(buffer)) != -1) {
                                os.write(buffer, 0, bytesRead);
                            }
                        }
                        fileScaricati++;
                        System.out.println("      ✓ Scaricato: " + fileName);
                    }
                }
                
                if (fileScaricati == 0) {
                    System.out.println("      Nessun file da scaricare per questa versione");
                } else {
                    System.out.println("      Totale file scaricati: " + fileScaricati);
                }
            }
        } catch (SQLException | IOException e) {
            System.err.println("  ✗ Errore download: " + e.getMessage());
            if (callback != null) callback.onError("Errore durante il download");
        }
    }
    
