		//// connect e disconnect
		synchronized boolean connect( Connection c, String u, String n, String p )
		{
			resetException();
			setConDb( c ); setJdbcUrl( u ); setJdbcName( n ); setJdbcPassword( p );
			////////////////////////////////////
			// new	
			// new	try {
