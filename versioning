				seq.setLoopCount( javax.sound.midi.Sequencer.LOOP_CONTINUOUSLY );
				//seq.setLoopEndPoint(5800); // 1,5 secondi di file midi
				seq.setLoopEndPoint(durata_ms); // 1,5 secondi di file midi
				
				while (th.isAlive()) {  }
				
