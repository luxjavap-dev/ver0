        int x = (int) blocco.get(1);
        int y = (int) blocco.get(2);
        int larghezza = (int) blocco.get(3);
        int altezza = (int) blocco.get(4);
        String testo = (String) blocco.get(5);

        JComponent comp;

        switch (tipo) {
            case winGenConstants.TEXTFIELD:
