	    JLabel iconLabel = new JLabel("⚠️", SwingConstants.CENTER);
	    iconLabel.setFont(new Font("Segoe UI", Font.PLAIN, 48));
	    
	    JLabel messageLabel = new JLabel("<html><center><b>L'APPLICAZIONE È STATA FERMATA!</b><br><br>" +
							    "Il sistema di versioning ha impostato lo stato STOPPED.<br>" +
							    "Il database è stato chiuso correttamente.<br>" +
							    "Il programma verrà chiuso tra pochi secondi.</center></html>");
	    messageLabel.setFont(new Font("Segoe UI", Font.PLAIN, 12));
	    
	    JPanel buttonPanel = new JPanel();
	    JButton okButton = new JButton();
	    okButton.setFont(new Font("Segoe UI", Font.BOLD, 14));
	    okButton.setBackground(new Color(200, 50, 50));
	    okButton.setForeground(Color.WHITE);
	    okButton.setFocusPainted(false);
	    okButton.setPreferredSize(new Dimension(120, 40));
	    
	    buttonPanel.add(okButton);
	    
	    mainPanel.add(iconLabel, BorderLayout.NORTH);
	    mainPanel.add(messageLabel, BorderLayout.CENTER);
	    mainPanel.add(buttonPanel, BorderLayout.SOUTH);
	    
	    stopDialog.add(mainPanel);
	    stopDialog.setSize(400, 250);
	    stopDialog.setLocationRelativeTo(null);
	    stopDialog.setAlwaysOnTop(true);
	    
	    final int[] countdown = {15};
	    okButton.setText("OK " + countdown[0]);
	    
	    // Timer per countdown
	    Timer stopTimer = new Timer(1000, new ActionListener() {
		   @Override
		   public void actionPerformed(ActionEvent e) {
			  countdown[0]--;
			  if (countdown[0] <= 0) {
				 ((Timer)e.getSource()).stop();
				 stopDialog.dispose();
				 System.exit(0);
			  } else {
				 okButton.setText("OK " + countdown[0]);
			  }
		   }
	    });
	    stopTimer.start();
	    
	    // ========== CHIUSURA CON TASTO X ==========
	    stopDialog.addWindowListener(new WindowAdapter() {
		   @Override
		   public void windowClosing(WindowEvent e) {
			  System.out.println("  [Versioning] Dialog STOP chiuso con X");
			  stopTimer.stop();
			  stopDialog.dispose();
			  System.exit(0);
		   }
	    });
	    // ==========================================
	    
	    // ========== CHIUSURA AUTOMATICA SE PERDE IL FOCUS ==========
	    stopDialog.addWindowFocusListener(new WindowAdapter() {
		   @Override
		   public void windowLostFocus(WindowEvent e) {
			  System.out.println("  [Versioning] Dialog STOP ha perso il focus - chiusura automatica");
			  stopTimer.stop();
			  stopDialog.dispose();
			  System.exit(0);
		   }
	    });
	    // ========================================================================
	    
	    // Pulsante OK
	    okButton.addActionListener(e -> {
		   stopTimer.stop();
		   stopDialog.dispose();
		   System.exit(0);
	    });
	    
	    stopDialog.setVisible(true);
	}
	/* END mostraFinestraStop() */
	/* END mostraFinestraStop() */
	
	
	
