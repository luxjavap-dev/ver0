					setConnected(true);
					return true;
				}
				////////////////////////////////////
				catch (java.sql.SQLInvalidAuthorizationSpecException e)
				{
					// <-- CATTURA SPECIFICA
					exception( e , "[wingen_sqlFunctions.SQLInvalidAuthorizationSpecException.setConnection()]" );
