	public class HashingManager
	{
		/**
		 * Calcola l'hash Bcrypt di una stringa in chiaro.
		 * Questo hash include automaticamente un salt generato casualmente
		 * e il cost factor (difficoltà computazionale).
		 *
		 * @param stringa La stringa in chiaro da hashare.
		 * @return La stringa dell'hash Bcrypt.
		 */
		public String myHashing(String stringa)
		{
			// BCrypt.gensalt(10) genera un salt e imposta il cost factor a 10.
			// Il cost factor (o "log rounds") determina quante iterazioni vengono eseguite.
			// Un valore di 10 significa 2^10 = 1024 iterazioni.
			// Più alto è il numero, più lento (e sicuro) sarà l'hashing,
			// ma anche più lento sarà il processo di verifica al login.
			// Scegli un valore che bilanci sicurezza e prestazioni accettabili.
			// Per la maggior parte degli usi, 10 o 12 sono buoni punti di partenza.
			String salt = BCrypt.gensalt(13); // Genera il salt a 13... non cambiarlo piu'!!!!
			String hashedStringa = BCrypt.hashpw(stringa, salt); // Hashes la stringa con il salt
			return hashedStringa;
		}
		
		
		// Puoi anche includere qui il metodo per la verifica, per completezza
		/**
		 * Verifica se una stringa in chiaro corrisponde a un hash Bcrypt memorizzato.
		 *
		 * @param stringaInChiaro La stringa che l'utente ha inserito.
		 * @param hashMemorizzato L'hash Bcrypt recuperato dal database.
		 * @return true se le stringa corrispondono, false altrimenti.
		 */
		public boolean checkStringa(String stringaInChiaro, String hashMemorizzato)
		{
			// BCrypt.checkpw gestisce automaticamente l'estrazione del salt
			// e del cost factor dall'hash memorizzato per effettuare la verifica.
			return BCrypt.checkpw(stringaInChiaro, hashMemorizzato);
		}

