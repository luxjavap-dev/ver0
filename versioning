import javax.swing.*;
import java.awt.*;
import java.io.*;
import java.nio.channels.FileChannel;
import java.nio.channels.FileLock;
import java.time.Duration;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.Vector;

public class WingenUtil
{
    private static BufferedWriter writer = null;
    private static boolean loggingEnabled = true;
    private static LocalDateTime startTime = null;
    private static FileChannel fileChannel = null;
    private static FileLock fileLock = null;
    private static FileOutputStream fileOutputStream = null;
    private static boolean alreadyClosed = false;
    private static int maxLogLevel = 9;

    // HELP -h -? -help
    public static void helpLog()
    {
		System.out.println("Parametri disponibili:");
		System.out.println("  -? / -h / -help   : mostra questa legenda");
		System.out.println("  -nolog		: disattiva il logging su file");
		System.out.println("  -tolevel=n	: imposta il livello massimo di logging (es. -tolevel=2)");
		return;
    }

    // Logging
    public static void disableLogging() {
        loggingEnabled = false;
    }

    public static void setMaxLogLevel(int livello) {
        maxLogLevel = livello;
    }

    public static int getMaxLogLevel() {
        return maxLogLevel;
    }

    public static void log(int livello, String msg) {
        print("I", String.valueOf(livello), msg);
    }

    public static void print(String tipo, int livello, String msg) {
        print(tipo, String.valueOf(livello), msg);
    }

    public static void print(String tipo, String livello, String messaggio) {
        if (!loggingEnabled || writer == null) return;

        try {
            int livelloInt = Integer.parseInt(livello);
            if (livelloInt > maxLogLevel) return;
        } catch (NumberFormatException e) {
            System.err.println("Livello non valido: " + livello);
            return;
        }

        LocalDateTime now = LocalDateTime.now();
        String timestamp = String.format("%s_%09d",
                now.format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss")),
                now.getNano());

        String tipoLog = tipo.equals("D") ? "[DEBUG---]" :
                         tipo.equals("E") ? "[ERROR---]" :
                         "[INFO----]";
        String caller = getCaller();

        String logLine = String.format("wingen_%s %s%s<%s> %s", timestamp, tipoLog, livello, caller, messaggio);

        try {
            writer.write(logLine);
            writer.newLine();
            writer.flush();
        } catch (IOException e) {
            System.err.println("Errore durante la scrittura nel log: " + e.getMessage());
        }
    }

    public static void open(String filename) {
        if (!loggingEnabled || writer != null) return;
        try {
            fileOutputStream = new FileOutputStream(filename, true);
            fileChannel = fileOutputStream.getChannel();
            fileLock = fileChannel.tryLock();

            if (fileLock != null) {
                writer = new BufferedWriter(new OutputStreamWriter(fileOutputStream));
            } else {
                System.err.println("Impossibile ottenere il lock sul file di log.");
            }
        } catch (IOException e) {
            System.err.println("Impossibile aprire il file di log: " + e.getMessage());
        }
    }

    public static void close() {
        if (!loggingEnabled || alreadyClosed) return;
        alreadyClosed = true;

        try {
            if (writer != null) {
                writer.flush();
                writer.close();
                writer = null;
            }
        } catch (IOException e) {
            System.err.println("Errore durante la chiusura del writer:");
            e.printStackTrace();
        }

        try {
            if (fileLock != null && fileLock.isValid()) {
                fileLock.release();
                fileLock = null;
            }
        } catch (IOException e) {
            System.err.println("Errore durante il rilascio del fileLock:");
            e.printStackTrace();
        }

        try {
            if (fileChannel != null && fileChannel.isOpen()) {
                fileChannel.close();
                fileChannel = null;
            }
        } catch (IOException e) {
            System.err.println("Errore durante la chiusura del fileChannel:");
            e.printStackTrace();
        }

        try {
            if (fileOutputStream != null) {
                fileOutputStream.close();
                fileOutputStream = null;
            }
        } catch (IOException e) {
            System.err.println("Errore durante la chiusura del fileOutputStream:");
            e.printStackTrace();
        }
    }

    private static String getCaller() {
        StackTraceElement[] stack = Thread.currentThread().getStackTrace();
        for (int i = 2; i < stack.length; i++) {
            if (!stack[i].getClassName().equals(WingenUtil.class.getName())) {
                return stack[i].getClassName() + "::" + stack[i].getMethodName();
            }
        }
        return "Unknown::Unknown";
    }

    // Timer
    public static void timeStart() {
        startTime = LocalDateTime.now();
    }

    public static String timeEnd() {
        if (startTime == null) return "000000:00:00_000000000";
        LocalDateTime now = LocalDateTime.now();
        Duration duration = Duration.between(startTime, now);

        long totalSeconds = duration.getSeconds();
        long hours = totalSeconds / 3600;
        long minutes = (totalSeconds % 3600) / 60;
        long seconds = totalSeconds % 60;
        int nanos = duration.getNano();

        return String.format("%06d:%02d:%02d_%09d", hours, minutes, seconds, nanos);
    }

    // Generazione dinamica GUI
    public static JComponent creaCampo(Vector<Object> blocco) {
