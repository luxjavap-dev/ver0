					setConnected(false);
					return false;
				}
				catch (java.sql.SQLNonTransientConnectionException e)
				{
					// <-- Connessione rifiutata/fallita (porta, IP, server spento, firewall)
					exception( e , "[wingen_sqlFunctions.SQLNonTransientConnectionException.setConnection()]" );
					System.err.println("ERRORE DB: Impossibile connettersi al database. Il server potrebbe essere spento, l'IP/porta errati, o un firewall blocca la connessione. Dettagli: " + e.getMessage());
