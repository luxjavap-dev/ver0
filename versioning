			}
			catch(MidiUnavailableException e)
			{
				//System.out.println( "Errore MidiUnavailableException" );
				e.printStackTrace();
			}
			catch(InvalidMidiDataException e2)
			{
				//System.out.println( "Errore InvalidMidiDataException" );
				e2.printStackTrace();
			}
			catch(Exception e3)
			{
				//System.out.println( "Errore InvalidMidiDataException" );
				e3.printStackTrace();
			}
		}
		private class soundThread extends Thread
		{
			public synchronized void run()
			{
				seq.setTickPosition( 1 );
				System.out.println( "START SOUND" );
				seq.start();
				seq.setLoopEndPoint(1500); // 1,5 secondi di file midi
				
			//ut.ritardoMillisec( 1100 );
			long startime = System.currentTimeMillis();
			while ( (System.currentTimeMillis() - startime) < durata_ms )
			{
				//non fa niente!
			}
				
				
				seq.stop();
				System.out.println( "STOP SOUND" );
			}
		}
	}
	
	
